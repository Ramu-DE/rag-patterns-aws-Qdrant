# ============================================================
# RAG Patterns — AWS + Qdrant
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# ── AWS Credentials ─────────────────────────────────────────
# Option A — AWS named profile (recommended for local dev)
AWS_PROFILE=default

# Option B — Explicit keys (e.g. STS assumed-role / CI)
AWS_ACCESS_KEY_ID=ASIA...your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_SESSION_TOKEN=your_session_token_here
AWS_DEFAULT_REGION=us-east-1

# ── Amazon Bedrock ───────────────────────────────────────────
# Default models used across all notebooks
BEDROCK_LLM_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_REGION=us-east-1

# ── Qdrant Cloud ─────────────────────────────────────────────
# Get from https://cloud.qdrant.io -> your cluster -> API Keys
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Amazon OpenSearch Serverless (optional fallback) ─────────
# Leave blank to skip — notebooks fall back to Qdrant in-memory
OPENSEARCH_ENDPOINT=https://<collection-id>.<region>.aoss.amazonaws.com

# ── Data paths ───────────────────────────────────────────────
# Absolute path to the PDF used in all notebooks
# Windows example:
PDF_PATH=C:\Users\YourName\RAG\data\climate.pdf
# Linux/Mac example:
# PDF_PATH=/home/yourname/RAG/data/climate.pdf
